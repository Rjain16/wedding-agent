# Base URL of your storage bucket (no trailing slash)
# After running process_album.py, upload the project-output/ folder contents here.
#
# Examples:
#   Supabase:  https://<project>.supabase.co/storage/v1/object/public/<bucket>
#   R2:        https://pub-<hash>.r2.dev
#   Firebase:  https://firebasestorage.googleapis.com/v0/b/<bucket>/o
NEXT_PUBLIC_STORAGE_BASE_URL=https://your-storage-url-here

# Optional: passcode to protect the event page (leave empty to disable)
NEXT_PUBLIC_EVENT_PASSCODE=

# Optional: name shown in the header (default: "Wedding Photos")
NEXT_PUBLIC_EVENT_NAME=Sarah & James Wedding
